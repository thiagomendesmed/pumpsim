{
  "expo": {
    "name": "PumpSim",
    "slug": "pumpsim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "bombasim",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thiagomendesmed.pumpsim",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "81fa1c1e-c485-4184-bdf6-5a56563236ec"
      }
    }
  }
}
